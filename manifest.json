{
  "manifest_version": 3,
  "name": "Better Japanese Captions",
  "version": "1.0.9",
  "description": "Cleaner line breaks for manually added Japanese YouTube captions. Auto-generated captions are not supported.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-budoux-captions": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Toggle Better Japanese Captions (on/off)"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
